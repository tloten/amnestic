{
  "manifest_version": 2,
  "name": "Amnestic",
  "version": "1.0",
  "description": "Preserve a site's 'known good' state and restore back to it - selective memory to reset metered paywalls.",
  "browser_specific_settings": {
    "gecko": {
      "id": "amnestic@tom.local",
      "strict_min_version": "128.0"
    }
  },
  "permissions": [
    "cookies",
    "storage",
    "activeTab"
  ],
  "optional_permissions": [
    "<all_urls>"
  ],
  "background": {
    "scripts": ["background.js"]
  },
  "browser_action": {
    "default_popup": "popup.html",
    "default_title": "Amnestic"
  }
}
