{
  "manifest_version": 2,
  "name": "Amnestic",
  "version": "1.0",
  "description": "Preserve a site's 'known good' state and restore back to it - selective memory to reset metered paywalls.",
  "browser_specific_settings": {
    "gecko": {
      "id": "amnestic@tloten.dev",
      "strict_min_version": "142.0",
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  },
  "permissions": [
    "cookies",
    "storage",
    "activeTab"
  ],
  "optional_permissions": [
    "<all_urls>"
  ],
  "icons": {
    "48": "icon.svg",
    "96": "icon.svg"
  },
  "background": {
    "scripts": ["background.js"]
  },
  "browser_action": {
    "default_popup": "popup.html",
    "default_title": "Amnestic",
    "default_icon": "icon.svg"
  }
}
